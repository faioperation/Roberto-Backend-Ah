generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum BusinessStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}



enum RoleName {
  SYSTEM_OWNER
  BUSINESS_OWNER
  BRANCH_MANAGER
  CUSTOMER
}

model User {
  id                   String     @id @default(uuid())
  email                String     @unique
  passwordHash         String     @map("password_hash")
  firstName            String?    @map("first_name")
  lastName             String?    @map("last_name")
  profilePicture       String?    @map("profile_picture")
  gender               String?
  country              String?
  phone                String?
  status               UserStatus @default(ACTIVE)
  isVerified           Boolean    @default(false) @map("is_verified")
  forgotPasswordStatus Boolean    @default(false) @map("forgot_password_status")
  lastLoginAt          DateTime?  @map("last_login_at")
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")
  deletedAt            DateTime?  @map("deleted_at")

  roles                 UserRole[]
  businesses            Business[]         @relation("BusinessOwner")
  createdBusinesses     Business[]         @relation("BusinessCreator")
  activityLogs          ActivityLog[]      @relation("ActivityLogCreator")
  systemOwnerPlans      SystemOwnerPlan[]  @relation("SystemOwnerPlanCreator")
  subscriptionPlans     SubscriptionPlan[] @relation("SubscriptionPlanCreator")
  createdBranchManagers BranchManager[]    @relation("BranchManagerCreator")
  createdBranches       Branch[]           @relation("BranchCreator")
  createdOrderBookings  OrderBooking[]     @relation("OrderBookingCreator")
  createdAppointmentBookings AppointmentBooking[] @relation("AppointmentBookingCreator")
  createdParcelDeliveries    ParcelDelivery[]     @relation("ParcelDeliveryCreator")
  createdPricings       Pricing[]          @relation("PricingCreator")
  createdCrmLeads       CrmLead[]          @relation("CrmLeadCreator")
  auditLogs             AuditLog[]         @relation("UserAuditLogs")

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        RoleName @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

enum DemoBookingStatus {
  CALLED
  PENDING
}

model DemoBooking {
  id           String            @id @default(uuid())
  email        String?           @unique
  mobileNumber String?           @map("mobile_number")
  date         DateTime?         @db.Date
  status       DemoBookingStatus @default(PENDING)
  credits      Int               @default(0)
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  @@map("demo_booking")
}

// System Owner Starts---------------------------

enum PlanName {
  NORMAL
  MEDIUM
  PREMIUM
}

enum PlanType {
  YEARLY
  MONTHLY
}

model SystemOwnerPlan {
  id           String    @id @default(uuid())
  name         PlanName  @unique
  price        Decimal
  billingCycle PlanType  @default(MONTHLY) @map("billing_cycle")
  planList     String[]  @map("plan_list")
  createdById  String?   @map("created_by_id")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  createdBy User? @relation("SystemOwnerPlanCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@map("system_owner_plan")
}

enum BusinessPlanType {
  MONTHLY
  YEARLY
}

model ActivityLog {
  id            String    @id @default(uuid())
  activityName  String?   @map("activity_name")
  activityTitle String?   @map("activity_title")
  activityType  String?   @map("activity_type")
  markAsRead    Boolean   @default(false) @map("mark_as_read")
  createdById   String?   @map("created_by_id")
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  createdBy User? @relation("ActivityLogCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@map("activity_log")
}

model SubscriptionPlan {
  id String @id @default(cuid())

  name String // CONNECT / CONVERT / CONTROL

  slug String @unique

  description String?

  monthlyPrice Float
  yearlyPrice  Float?

  currency String @default("USD")

  stripeProductId      String?
  stripeMonthlyPriceId String?
  stripeYearlyPriceId  String?

  isActive Boolean @default(true)

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  createdBy   User?   @relation("SubscriptionPlanCreator", fields: [createdById], references: [id], onDelete: SetNull)

  features              SubscriptionFeature[]
  businessSubscriptions BusinessSubscription[]
}

model SubscriptionFeature {
  id String @id @default(cuid())

  planId String
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  key   String
  value String

  createdAt DateTime @default(now())
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  INACTIVE
  UNPAID
}

enum SubscriptionBillingCycle {
  MONTHLY
  YEARLY
}

model BusinessSubscription {
  id           String                   @id @default(cuid())
  businessId   String                   @map("business_id")
  planId       String                   @map("plan_id")
  status       SubscriptionStatus       @default(INACTIVE)
  billingCycle SubscriptionBillingCycle @default(MONTHLY) @map("billing_cycle")

  stripeCustomerId     String? @map("stripe_customer_id")
  stripeSubscriptionId String? @unique @map("stripe_subscription_id")

  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  business Business              @relation("BusinessSubscriptions", fields: [businessId], references: [id], onDelete: Cascade)
  plan     SubscriptionPlan      @relation(fields: [planId], references: [id])
  invoices SubscriptionInvoice[]

  @@map("business_subscriptions")
}

model SubscriptionInvoice {
  id              String                   @id @default(cuid())
  businessId      String                   @map("business_id")
  subscriptionId  String                   @map("subscription_id")
  invoiceNo       String                   @unique @map("invoice_no")
  amount          Float
  status          String                   @default("paid")
  billingCycle    SubscriptionBillingCycle @map("billing_cycle")
  stripeInvoiceId String?                  @unique @map("stripe_invoice_id")
  invoicePath     String?                  @map("invoice_path")
  invoiceUrl      String?                  @map("invoice_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  business     Business             @relation("BusinessInvoices", fields: [businessId], references: [id], onDelete: Cascade)
  subscription BusinessSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("subscription_invoices")
}

// System Owner ends---------------------------

// Business Owner --------------------------
enum BranchManagerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Business {
  id           String           @id @default(uuid())
  ownerId      String           @map("owner_id")
  name         String
  logo         String?
  email        String?
  phone        String?
  country      String?
  address      String?
  industry     String?          @map("industry")
  status       BusinessStatus   @default(INACTIVE)
  description  String?
  planId       String?          @map("plan_id")
  planCycle    BusinessPlanType @default(MONTHLY) @map("plan_cycle")
  createdById  String?          @map("created_by_id")
  credits      Int              @default(0)
  businessType BusinessType?    @map("business_type")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  deletedAt    DateTime?        @map("deleted_at")

  owner               User                   @relation("BusinessOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdBy           User?                  @relation("BusinessCreator", fields: [createdById], references: [id], onDelete: SetNull)
  branches            Branch[]
  branchManagers      BranchManager[]        @relation("BusinessBranchManagers")
  orderBookings       OrderBooking[]         @relation("BusinessOrderBookings")
  appointmentBookings AppointmentBooking[]   @relation("BusinessAppointmentBookings")
  parcelDeliveries    ParcelDelivery[]       @relation("BusinessParcelDeliveries")
  pricings            Pricing[]              @relation("BusinessPricings")
  crmLeads            CrmLead[]              @relation("BusinessCrmLeads")
  socialConnections   SocialConnection[]     @relation("BusinessSocialConnections")
  conversations       Conversation[]         @relation("BusinessConversations")
  subscriptions       BusinessSubscription[] @relation("BusinessSubscriptions")
  invoices            SubscriptionInvoice[]  @relation("BusinessInvoices")

  whatsappAccounts      WhatsappAccount[]      @relation("BusinessWhatsappAccounts")
  whatsappContacts      WhatsappContact[]      @relation("BusinessWhatsappContacts")
  whatsappConversations WhatsappConversation[] @relation("BusinessWhatsappConversations")
  whatsappMessages      WhatsappMessage[]      @relation("BusinessWhatsappMessages")
  chatSummaries         ChatSummary[]
  auditLogs             AuditLog[]             @relation("BusinessAuditLogs")

  @@map("businesses")
}

model Branch {
  id          String    @id @default(uuid())
  businessId  String    @map("business_id")
  managerId   String?   @map("manager_id")
  name        String
  email       String?
  phone       String?
  address     String?
  createdById String?   @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  business          Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  manager           BranchManager?     @relation(fields: [managerId], references: [id], onDelete: SetNull)
  createdBy         User?              @relation("BranchCreator", fields: [createdById], references: [id], onDelete: SetNull)
  orderBookings     OrderBooking[]     @relation("BranchOrderBookings")
  appointmentBookings AppointmentBooking[]   @relation("BranchAppointmentBookings")
  parcelDeliveries    ParcelDelivery[]       @relation("BranchParcelDeliveries")
  crmLeads          CrmLead[]          @relation("BranchCrmLeads")
  pricings          Pricing[]          @relation("BranchPricings")
  socialConnections SocialConnection[] @relation("BranchSocialConnections")
  conversations     Conversation[]     @relation("BranchConversations")
  whatsappAccounts  WhatsappAccount[]  @relation("BranchWhatsappAccounts")

  @@map("branches")
}

model BranchManager {
  id          String              @id @default(uuid())
  name        String
  email       String              @unique
  password    String
  status      BranchManagerStatus @default(ACTIVE)
  createdById String?             @map("created_by")
  businessId  String              @map("business_id")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  deletedAt   DateTime?           @map("deleted_at")

  business  Business @relation("BusinessBranchManagers", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("BranchManagerCreator", fields: [createdById], references: [id], onDelete: SetNull)
  branches  Branch[]

  @@map("branch_managers")
}

enum BusinessType {
  ORDER_BOOKING
  APPOINTMENT_BOOKING
  PARCEL_DELIVERY
}

enum FeatureName {
  ORDER_BOOKING
  APPOINTMENT_BOOKING
  PARCEL_DELIVERY
}

enum LeadStatus {
  COLD
  WARM
  BOOKED
  HOT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

// ------------------------------------
// Order Booking & Details
// ------------------------------------
model OrderBooking {
  id             String        @id @default(uuid())
  businessId     String        @map("business_id")
  branchId       String?       @map("branch_id")
  createdById    String?       @map("created_by")
  customerName   String        @map("customer_name")
  customerNumber String        @map("customer_number")
  email          String?
  price          String
  note           String?       @db.Text
  status         BookingStatus @default(PENDING)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  business       Business      @relation("BusinessOrderBookings", fields: [businessId], references: [id], onDelete: Cascade)
  branch         Branch?       @relation("BranchOrderBookings", fields: [branchId], references: [id], onDelete: SetNull)
  createdBy      User?         @relation("OrderBookingCreator", fields: [createdById], references: [id], onDelete: SetNull)
  orderDetails   OrderDetails?

  @@map("order_bookings")
}

model OrderDetails {
  id              String       @id @default(uuid())
  businessId      String       @map("business_id")
  branchId        String?      @map("branch_id")
  orderId         String       @unique @map("order_id")
  deliveryDate    String?      @map("delivery_date")
  deliveryAddress String?      @map("delivery_address")
  productType     String?      @map("product_type")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")

  order           OrderBooking @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_details")
}

// ------------------------------------
// Appointment Booking & Details
// ------------------------------------
model AppointmentBooking {
  id                 String              @id @default(uuid())
  businessId         String              @map("business_id")
  branchId           String?             @map("branch_id")
  createdById        String?             @map("created_by")
  customerName       String              @map("customer_name")
  customerNumber     String              @map("customer_number")
  email              String?
  price              String
  note               String?             @db.Text
  status             BookingStatus       @default(PENDING)
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  deletedAt          DateTime?           @map("deleted_at")

  business           Business            @relation("BusinessAppointmentBookings", fields: [businessId], references: [id], onDelete: Cascade)
  branch             Branch?             @relation("BranchAppointmentBookings", fields: [branchId], references: [id], onDelete: SetNull)
  createdBy          User?               @relation("AppointmentBookingCreator", fields: [createdById], references: [id], onDelete: SetNull)
  appointmentDetails AppointmentDetails?

  @@map("appointment_bookings")
}

model AppointmentDetails {
  id              String             @id @default(uuid())
  businessId      String             @map("business_id")
  branchId        String?            @map("branch_id")
  appointmentId   String             @unique @map("appointment_id")
  appointmentDate String?            @map("appointment_date")
  appointmentTime DateTime?          @map("appointment_time")
  platform        String?
  duration        String?
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  deletedAt       DateTime?          @map("deleted_at")

  appointment     AppointmentBooking @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("appointment_details")
}

// ------------------------------------
// Parcel Delivery & Details
// ------------------------------------
model ParcelDelivery {
  id             String         @id @default(uuid())
  businessId     String         @map("business_id")
  branchId       String?        @map("branch_id")
  createdById    String?        @map("created_by")
  customerName   String         @map("customer_name")
  customerNumber String         @map("customer_number")
  email          String?
  price          String
  note           String?        @db.Text
  status         BookingStatus  @default(PENDING)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  deletedAt      DateTime?      @map("deleted_at")

  business       Business       @relation("BusinessParcelDeliveries", fields: [businessId], references: [id], onDelete: Cascade)
  branch         Branch?        @relation("BranchParcelDeliveries", fields: [branchId], references: [id], onDelete: SetNull)
  createdBy      User?          @relation("ParcelDeliveryCreator", fields: [createdById], references: [id], onDelete: SetNull)
  parcelDetails  ParcelDetails?

  @@map("parcel_deliveries")
}

model ParcelDetails {
  id               String         @id @default(uuid())
  businessId       String         @map("business_id")
  branchId         String?        @map("branch_id")
  parcelDeliveryId String         @unique @map("parcel_delivery_id")
  pickupAddress    String?        @map("pickup_address")
  deliveryDate     String?        @map("delivery_date")
  deliveryAddress  String?        @map("delivery_address")
  productType      String?        @map("product_type")
  productHeight    String?        @map("product_height")
  productWeight    String?        @map("product_weight")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  deletedAt        DateTime?      @map("deleted_at")

  parcelDelivery   ParcelDelivery @relation(fields: [parcelDeliveryId], references: [id], onDelete: Cascade)

  @@map("parcel_details")
}

// ------------------------------------
// Features, Additional Details & Payments
// ------------------------------------
model Feature {
  id          String      @id @default(uuid())
  featureName FeatureName @map("feature_name")

  additionalDetails AdditionalDetail[]

  @@map("features")
}

model AdditionalDetail {
  id           String    @id @default(uuid())
  businessId   String    @map("business_id")
  branchId     String?   @map("branch_id")
  featureId    String?   @map("feature_id")
  referenceId  String    @map("reference_id") // orderBooking, appointmentBooking, parcelDelivery, or crmLead ID
  key          String
  value        String    @db.Text
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  feature      Feature?  @relation(fields: [featureId], references: [id], onDelete: SetNull)

  @@map("additional_details")
}

model PaymentDetail {
  id            String        @id @default(uuid())
  referenceId   String        @map("reference_id")
  createdById   String?       @map("created_by")
  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")
  paymentMethod String?       @map("payment_method")
  transactionId String?       @map("transaction_id")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")

  @@map("payment_details")
}

model Pricing {
  id            String  @id @default(uuid())
  businessId    String  @map("business_id")
  createdById   String? @map("created_by")
  branchId      String? @map("branch_id")

  ruleName      String  @map("rule_name")
  type          String  // e.g., "FLAT", "WEIGHT", "DISTANCE", "HOURLY", "FORMULA"
  configuration Json    // Structured pricing details and math formulas
  status        Boolean @default(true)

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  business      Business  @relation("BusinessPricings", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy     User?     @relation("PricingCreator", fields: [createdById], references: [id], onDelete: SetNull)
  branch        Branch?   @relation("BranchPricings", fields: [branchId], references: [id], onDelete: SetNull)

  @@map("pricings")
}

enum SourceEnum {
  WEBSITE
  SOCIAL_MEDIA
  REFERRAL
  COLD_CALL   
  OTHER
}

model CrmLead {
  id          String   @id @default(uuid())
  businessId  String   @map("business_id")
  createdById String?  @map("created_by")
  branchId    String?  @map("branch_id")

  name        String
  email       String?
  phone       String?
  source      SourceEnum?
  address     String?
  note        String?
  status      LeadStatus @default(COLD)

  metadata    Json?    // Specific lead collection fields

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  business    Business       @relation("BusinessCrmLeads", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy   User?          @relation("CrmLeadCreator", fields: [createdById], references: [id], onDelete: SetNull)
  branch      Branch?        @relation("BranchCrmLeads", fields: [branchId], references: [id], onDelete: SetNull)

  @@map("crm_leads")
}

model AuditLog {
  id          String   @id @default(uuid())
  businessId  String   @map("business_id")
  userId      String?  @map("user_id")
  action      String   // e.g. "STATUS_CHANGE", "ASSIGNMENT_CHANGE", "PRICING_RULE_UPDATE"
  targetTable String   @map("target_table") // e.g. "OrderBooking", "CrmLead"
  targetId    String   @map("target_id")
  oldValues   Json?    @map("old_values")
  newValues   Json?    @map("new_values")
  createdAt   DateTime @default(now()) @map("created_at")

  business    Business @relation("BusinessAuditLogs", fields: [businessId], references: [id], onDelete: Cascade)
  user        User?    @relation("UserAuditLogs", fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

// Facebook Messenger Integration ----------------

model SocialConnection {
  id          String    @id @default(uuid())
  businessId  String    @map("business_id")
  branchId    String?   @map("branch_id")
  provider    String // e.g. 'facebook'
  pageId      String    @map("page_id")
  pageName    String    @map("page_name")
  accessToken String    @map("access_token")
  tokenExpiry DateTime? @map("token_expiry")
  isActive    Boolean   @default(true) @map("is_active")
  aiReply     Boolean   @default(true) @map("ai_reply")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  business Business @relation("BusinessSocialConnections", fields: [businessId], references: [id], onDelete: Cascade)
  branch   Branch?  @relation("BranchSocialConnections", fields: [branchId], references: [id], onDelete: SetNull)

  @@map("social_connections")
}

model Conversation {
  id            String    @id @default(uuid())
  businessId    String    @map("business_id")
  branchId      String?   @map("branch_id")
  platform      String // e.g. 'messenger'
  customerId    String    @map("customer_id")
  customerName  String?   @map("customer_name")
  lastMessage   String?   @map("last_message")
  lastMessageAt DateTime? @map("last_message_at")
  aiReply       Boolean   @default(true) @map("ai_reply")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  business Business  @relation("BusinessConversations", fields: [businessId], references: [id], onDelete: Cascade)
  branch   Branch?   @relation("BranchConversations", fields: [branchId], references: [id], onDelete: SetNull)
  messages Message[] @relation("ConversationMessages")

  @@unique([businessId, platform, customerId])
  @@map("conversations")
}

model Message {
  id                String   @id @default(uuid())
  conversationId    String   @map("conversation_id")
  senderType        String // 'business' or 'customer'
  senderId          String   @map("sender_id")
  type              String?  @default("text") // 'text', 'image', 'video', 'audio', 'file'
  messageText       String?  @map("message_text")
  mediaUrl          String?  @map("media_url")
  filePath          String?  @map("file_path")
  platformMessageId String?  @unique @map("platform_message_id")
  rawPayload        Json?    @map("raw_payload")
  aiReply           Boolean  @default(true) @map("ai_reply")
  createdAt         DateTime @default(now()) @map("created_at")

  conversation Conversation @relation("ConversationMessages", fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// Business Owner ends --------------------------

// WhatsApp Cloud API Integration ----------------

enum WhatsappAccountStatus {
  ACTIVE
  INACTIVE
  DISCONNECTED
}

model WhatsappAccount {
  id            String                @id @default(uuid())
  businessId    String                @map("business_id")
  branchId      String?               @map("branch_id")
  wabaId        String                @map("waba_id")
  phoneNumberId String                @map("phone_number_id")
  phoneNumber   String                @map("phone_number")
  accessToken   String                @map("access_token")
  status        WhatsappAccountStatus @default(ACTIVE)
  aiReply       Boolean               @default(true) @map("ai_reply")
  metadata      Json?
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")

  business      Business               @relation("BusinessWhatsappAccounts", fields: [businessId], references: [id], onDelete: Cascade)
  branch        Branch?                @relation("BranchWhatsappAccounts", fields: [branchId], references: [id], onDelete: SetNull)
  contacts      WhatsappContact[]      @relation("AccountWhatsappContacts")
  conversations WhatsappConversation[] @relation("AccountWhatsappConversations")
  messages      WhatsappMessage[]      @relation("AccountWhatsappMessages")

  @@unique([businessId, phoneNumberId])
  @@map("whatsapp_accounts")
}

model WhatsappContact {
  id                String    @id @default(uuid())
  businessId        String    @map("business_id")
  whatsappAccountId String    @map("whatsapp_account_id")
  waUserId          String    @map("wa_user_id")
  name              String?
  phoneNumber       String    @map("phone_number")
  profilePicture    String?   @map("profile_picture")
  lastMessageAt     DateTime? @map("last_message_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  business        Business               @relation("BusinessWhatsappContacts", fields: [businessId], references: [id], onDelete: Cascade)
  whatsappAccount WhatsappAccount        @relation("AccountWhatsappContacts", fields: [whatsappAccountId], references: [id], onDelete: Cascade)
  conversations   WhatsappConversation[] @relation("ContactWhatsappConversations")
  messages        WhatsappMessage[]      @relation("ContactWhatsappMessages")

  @@unique([businessId, waUserId])
  @@map("whatsapp_contacts")
}

model WhatsappConversation {
  id                String    @id @default(uuid())
  businessId        String    @map("business_id")
  whatsappAccountId String    @map("whatsapp_account_id")
  contactId         String    @map("contact_id")
  lastMessageId     String?   @map("last_message_id")
  unreadCount       Int       @default(0) @map("unread_count")
  lastMessageAt     DateTime? @map("last_message_at")
  aiReply           Boolean   @default(true) @map("ai_reply")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  business        Business          @relation("BusinessWhatsappConversations", fields: [businessId], references: [id], onDelete: Cascade)
  whatsappAccount WhatsappAccount   @relation("AccountWhatsappConversations", fields: [whatsappAccountId], references: [id], onDelete: Cascade)
  contact         WhatsappContact   @relation("ContactWhatsappConversations", fields: [contactId], references: [id], onDelete: Cascade)
  messages        WhatsappMessage[] @relation("ConversationWhatsappMessages")

  @@unique([businessId, contactId])
  @@map("whatsapp_conversations")
}

enum WhatsappMessageDirection {
  INCOMING
  OUTGOING
}

enum WhatsappMessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

model WhatsappMessage {
  id                String                   @id @default(uuid())
  businessId        String                   @map("business_id")
  whatsappAccountId String                   @map("whatsapp_account_id")
  conversationId    String                   @map("conversation_id")
  contactId         String                   @map("contact_id")
  metaMessageId     String?                  @unique @map("meta_message_id")
  direction         WhatsappMessageDirection
  type              String // text, image, video, audio, document, sticker, template
  text              String?
  mediaUrl          String?                  @map("media_url")
  status            WhatsappMessageStatus?
  rawPayload        Json?                    @map("raw_payload")
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")

  business        Business             @relation("BusinessWhatsappMessages", fields: [businessId], references: [id], onDelete: Cascade)
  whatsappAccount WhatsappAccount      @relation("AccountWhatsappMessages", fields: [whatsappAccountId], references: [id], onDelete: Cascade)
  conversation    WhatsappConversation @relation("ConversationWhatsappMessages", fields: [conversationId], references: [id], onDelete: Cascade)
  contact         WhatsappContact      @relation("ContactWhatsappMessages", fields: [contactId], references: [id], onDelete: Cascade)

  @@map("whatsapp_messages")
}

model AgentTraining {
  id                  String    @id @default(uuid())
  systemPrompt        String?   @map("system_prompt")
  businessInformation String?   @map("business_information")
  productInformation  Json?     @map("product_information")
  policiesGuidelines  Json?     @map("policies_guidelines")
  faq                 Json?
  businessId          String    @map("business_id")
  rowText             String?   @map("row_text")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  @@map("agent_training")
}

model Agent {
  id         String    @id @default(uuid())
  businessId String    @map("business_id")
  branchId   String?   @map("branch_id")
  rulesFile  String    @map("rules_file")
  vapiId     String?   @map("vapi_id")
  metadata   Json?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@map("agents")
}

model ChatSummary {
  id             String @id @default(uuid())
  conversationId String @unique @map("conversation_id")
  businessId     String @map("business_id")

  items          String?
  pickupArea     String?  @map("pickup_area")
  destination    String?
  weight         String?
  pickupDateTime String?  @map("pickup_date_time")
  currentStatus  String?  @map("current_status")
  recentSummary  String?  @map("recent_summary")
  bookingInfo    Json?    @map("booking_info")
  summary        String?
  keyPoints      String[] @map("key_points")
  intent         String?
  confidence     String?
  reason         String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("chat_summaries")
}
