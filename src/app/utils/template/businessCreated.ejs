<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Welcome to Robarto – Your Business is Live!</title>
  <style>
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      line-height: 1.6;
      color: #333;
      margin: 0;
      padding: 0;
      background-color: #f4f7f9;
    }

    .container {
      max-width: 600px;
      margin: 30px auto;
      background: #ffffff;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.07);
    }

    .header {
      background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
      padding: 40px 30px;
      text-align: center;
      color: #ffffff;
    }

    .header h1 {
      margin: 0;
      font-size: 28px;
      font-weight: 700;
      letter-spacing: 0.5px;
    }

    .header p {
      margin: 10px 0 0 0;
      font-size: 15px;
      opacity: 0.9;
    }

    .content {
      padding: 40px;
    }

    .welcome-text {
      font-size: 20px;
      color: #1f2937;
      font-weight: 600;
      margin-bottom: 10px;
    }

    .intro {
      color: #4b5563;
      font-size: 14px;
      margin-bottom: 24px;
    }

    /* Credentials Box */
    .credentials-box {
      background: linear-gradient(135deg, #ede9fe 0%, #fce7f3 100%);
      border: 1px solid #c4b5fd;
      border-radius: 12px;
      padding: 20px 24px;
      margin: 20px 0;
    }

    .credentials-box h3 {
      margin: 0 0 14px 0;
      font-size: 13px;
      font-weight: 700;
      color: #5b21b6;
      text-transform: uppercase;
      letter-spacing: 0.6px;
    }

    .cred-row {
      display: flex;
      align-items: center;
      margin-bottom: 10px;
    }

    .cred-row:last-child {
      margin-bottom: 0;
    }

    .cred-label {
      min-width: 110px;
      font-size: 12px;
      font-weight: 600;
      color: #7c3aed;
    }

    .cred-value {
      font-size: 13px;
      font-weight: 700;
      color: #1f2937;
      background: rgba(255,255,255,0.7);
      padding: 3px 10px;
      border-radius: 6px;
      letter-spacing: 0.3px;
    }

    /* Details Card */
    .details-card {
      background: #f9fafb;
      border: 1px solid #e5e7eb;
      border-radius: 12px;
      padding: 24px;
      margin: 20px 0;
    }

    .details-card h3 {
      margin: 0 0 14px 0;
      font-size: 13px;
      font-weight: 700;
      color: #374151;
      text-transform: uppercase;
      letter-spacing: 0.6px;
    }

    .details-row {
      display: flex;
      justify-content: space-between;
      margin-bottom: 12px;
      border-bottom: 1px solid #f3f4f6;
      padding-bottom: 12px;
    }

    .details-row:last-child {
      margin-bottom: 0;
      border-bottom: none;
      padding-bottom: 0;
    }

    .details-label {
      color: #6b7280;
      font-weight: 500;
      font-size: 13px;
    }

    .details-value {
      color: #111827;
      font-weight: 600;
      font-size: 13px;
      text-align: right;
    }

    .badge {
      display: inline-block;
      background: #d1fae5;
      color: #065f46;
      font-size: 11px;
      font-weight: 700;
      padding: 3px 10px;
      border-radius: 999px;
      letter-spacing: 0.5px;
    }

    /* Invoice section */
    .invoice-section {
      background: linear-gradient(135deg, #f0f4ff 0%, #faf5ff 100%);
      border: 1px solid #c7d2fe;
      border-radius: 12px;
      padding: 20px 24px;
      margin: 20px 0;
      text-align: center;
    }

    .invoice-section p {
      color: #4338ca;
      font-size: 14px;
      margin: 0 0 12px 0;
      font-weight: 500;
    }

    .btn {
      display: inline-block;
      background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
      color: #ffffff !important;
      text-decoration: none;
      padding: 14px 30px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 16px;
      box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
      margin: 20px auto;
      display: block;
      text-align: center;
    }

    .btn-invoice {
      display: inline-block;
      background: #ffffff;
      color: #6366f1 !important;
      text-decoration: none;
      padding: 12px 28px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 14px;
      border: 2px solid #6366f1;
    }

    .divider {
      height: 1px;
      background: #e5e7eb;
      margin: 28px 0;
    }

    .footer {
      background: #f9fafb;
      padding: 25px;
      text-align: center;
      color: #9ca3af;
      font-size: 13px;
      border-top: 1px solid #f3f4f6;
    }

    .warning-note {
      background: #fffbeb;
      border: 1px solid #fde68a;
      border-radius: 8px;
      padding: 12px 16px;
      font-size: 13px;
      color: #92400e;
      margin: 16px 0;
    }
  </style>
</head>

<body>
  <div class="container">
    <div class="header">
      <h1>🚀 Welcome to Robarto!</h1>
      <p>Your business account has been created and is ready to use.</p>
    </div>

    <div class="content">
      <p class="welcome-text">Hello <%= ownerName %>,</p>
      <p class="intro">
        Your business account on <strong>Robarto</strong> has been successfully set up by our team.
        Below are your login credentials and business details — please keep them safe.
      </p>

      <!-- Login Credentials -->
      <div class="credentials-box">
        <h3>🔐 Your Login Credentials</h3>
        <div class="cred-row">
          <div class="cred-label">Email:</div>
          <div class="cred-value"><%= ownerEmail %></div>
        </div>
        <div class="cred-row">
          <div class="cred-label">Password:</div>
          <div class="cred-value"><%= ownerPassword %></div>
        </div>
      </div>

      <div class="warning-note">
        ⚠️ Please log in and change your password immediately for security.
      </div>

      <!-- Business Details -->
      <div class="details-card">
        <h3>🏢 Business Information</h3>
        <div class="details-row">
          <div class="details-label">Business Name:</div>
          <div class="details-value"><%= businessName %></div>
        </div>
        <% if (businessType) { %>
        <div class="details-row">
          <div class="details-label">Business Type:</div>
          <div class="details-value"><%= businessType %></div>
        </div>
        <% } %>
        <% if (planName) { %>
        <div class="details-row">
          <div class="details-label">Plan:</div>
          <div class="details-value"><%= planName %></div>
        </div>
        <div class="details-row">
          <div class="details-label">Billing Cycle:</div>
          <div class="details-value"><%= billingCycle %></div>
        </div>
        <div class="details-row">
          <div class="details-label">Amount:</div>
          <div class="details-value"><%= currency || 'USD' %> <%= Number(amount || 0).toFixed(2) %></div>
        </div>
        <% } %>
        <div class="details-row">
          <div class="details-label">Status:</div>
          <div class="details-value"><span class="badge">ACTIVE</span></div>
        </div>
      </div>

      <!-- Invoice Download -->
      <% if (invoiceUrl) { %>
      <div class="invoice-section">
        <p>📄 Your subscription invoice is ready to download.</p>
        <a href="<%= invoiceUrl %>" class="btn-invoice" target="_blank">Download Invoice PDF</a>
      </div>
      <% } %>

      <a href="<%= frontendUrl %>" class="btn" target="_blank">Go to Dashboard</a>

      <div class="divider"></div>

      <p style="color: #6b7280; font-size: 13px; text-align: center;">
        Need help getting started? Feel free to reply to this email and our team will assist you.
      </p>
    </div>

    <div class="footer">
      &copy; <%= new Date().getFullYear() %> Robarto. All rights reserved.<br>
      Automate your customer communications with Robarto AI.
    </div>
  </div>
</body>

</html>
